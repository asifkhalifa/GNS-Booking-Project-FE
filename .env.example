# Frontend-only mode (Spring Boot backend).
# Restart `npm run dev` after changes.
#
# Backend base URL (no trailing slash). Example:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Public (browser) — UPI labels and QR path in /public.
NEXT_PUBLIC_UPI_ID=yourvpa@paytm
NEXT_PUBLIC_UPI_PAYEE_NAME=Your name
NEXT_PUBLIC_UPI_QR_IMAGE=/upi-paytm-qr.png
