# Copy to .env.local and fill in. Restart `npm run dev` after changes.

# Firebase Admin (Firestore) — pick ONE:
# (A) Recommended: path to the downloaded JSON file (no multiline secrets in .env):
# FIREBASE_SERVICE_ACCOUNT_FILE=config/firebase-service-account.json
# (B) base64 (one line):  cat serviceAccount.json | base64 | tr -d '\n'
# FIREBASE_SERVICE_ACCOUNT_BASE64=
# (C) Entire JSON on ONE line only — multiline FIREBASE_SERVICE_ACCOUNT_JSON={ ... } is INVALID (dotenv only reads "{").
# FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated emails that get admin UI (must match verify-otp user emails).
ADMIN_EMAILS=you@example.com

# SMTP — same as Spring Boot mail (maps to spring.mail.*):
#   SMTP_HOST          → spring.mail.host
#   SMTP_PORT          → spring.mail.port
#   SMTP_USER          → spring.mail.username
#   SMTP_PASS          → spring.mail.password (Gmail app password; spaces OK — stripped in code)
#   SMTP_FROM          → From header (often same as username for Gmail)
# Optional in dev — OTP is logged to the server console if unset.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public (browser) — UPI labels and QR path in /public
NEXT_PUBLIC_UPI_ID=yourvpa@paytm
NEXT_PUBLIC_UPI_PAYEE_NAME=Your name
NEXT_PUBLIC_UPI_QR_IMAGE=/upi-paytm-qr.png

# Optional: only if the browser calls another host for APIs (default is same-origin /api).
# NEXT_PUBLIC_API_BASE_URL=

# Optional: admin tickets static demo
# NEXT_PUBLIC_ADMIN_BOOKINGS_STATIC=true

# Optional: POST /api/admin/reseed-seats — long random string; header x-seat-reseed-secret
# After `npm run dev`: npm run seed:seats  (or curl; optional RESEED_URL=http://127.0.0.1:3000)
# Or wipe + rewrite seats directly (no dev server): npm run apply-seat-chart
# SEAT_RESEED_SECRET=

# Optional: throttle stale-booking scan (ms). Default 45000. See DEPLOY.md.
# EXPIRE_BOOKINGS_MIN_INTERVAL_MS=45000

# --- Production (e.g. Vercel): use FIREBASE_SERVICE_ACCOUNT_BASE64 (see npm run firebase:encode-key)
# Do not commit service account JSON. Full checklist: DEPLOY.md
